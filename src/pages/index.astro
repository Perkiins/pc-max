---
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="PC MAX Barcelona — Reparación de ordenadores, desarrollo web y programación a medida en Barcelona." />
  <meta name="keywords" content="reparación ordenadores Barcelona, desarrollo web Barcelona, programación a medida, PC MAX" />
  <title>PC MAX | Tecnología en Barcelona</title>
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <a href="#inicio" class="nav-logo">
        <img src="/logo.png" alt="PC MAX" height="38" />
      </a>
      <ul>
        <li><a href="#servicios">Servicios</a></li>
        <li><a href="#proyectos">Proyectos</a></li>
        <li><a href="#contacto">Contacto</a></li>
      </ul>
      <a href="#contacto" class="btn btn-primary btn-sm">Contáctame</a>
    </div>
  </nav>

  <!-- HERO -->
  <section id="inicio" class="hero">
    <div class="hero-inner">
      <span class="badge">📍 Barcelona</span>
      <h1>Tecnología que <span class="accent">funciona</span><br/>para ti</h1>
      <p class="hero-sub">Reparación de ordenadores · Desarrollo web · Programación a medida</p>
      <div class="hero-ctas">
        <a href="#contacto" class="btn btn-primary">Contáctame</a>
        <a href="#servicios" class="btn btn-ghost">Ver servicios →</a>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section id="servicios">
    <div class="container">
      <h2>¿En qué puedo ayudarte?</h2>
      <p class="section-sub">Soluciones tecnológicas adaptadas a lo que necesitas</p>
      <div class="grid-3">
        <div class="card">
          <div class="card-icon">🔧</div>
          <h3>Reparación de ordenadores</h3>
          <p>Diagnóstico completo, eliminación de virus, cambio de componentes, optimización y recuperación de datos.</p>
          <ul>
            <li>PC y portátiles</li>
            <li>Limpieza interna</li>
            <li>Cambio de disco / RAM</li>
            <li>Problemas de arranque</li>
            <li>Eliminación de virus</li>
          </ul>
        </div>
        <div class="card featured">
          <div class="card-icon">🌐</div>
          <h3>Diseño y desarrollo web</h3>
          <p>Páginas web modernas, rápidas y optimizadas para buscadores. Desde landing pages hasta tiendas online completas.</p>
          <ul>
            <li>Diseño personalizado</li>
            <li>Tiendas Shopify</li>
            <li>SEO incluido</li>
            <li>Hosting gratuito disponible</li>
            <li>Mantenimiento</li>
          </ul>
        </div>
        <div class="card">
          <div class="card-icon">💻</div>
          <h3>Programación a medida</h3>
          <p>Desarrollo de aplicaciones web, automatizaciones de procesos e integraciones con APIs y sistemas externos.</p>
          <ul>
            <li>Apps web completas</li>
            <li>Automatizaciones</li>
            <li>Integraciones de APIs</li>
            <li>Scripts y herramientas</li>
            <li>Google AppScript</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- PROYECTOS -->
  <section id="proyectos" class="dark-section">
    <div class="container">
      <h2>Proyectos destacados</h2>
      <p class="section-sub">Algunos de los proyectos en los que he trabajado</p>
      <div class="grid-2">
        <div class="project-card">
          <div class="project-img project-img--code">
            <span>📊</span>
            <p>Panel interno</p>
          </div>
          <div class="project-body">
            <div class="project-header">
              <h3>JackBeds — Panel de gestión</h3>
              <span class="tag tag-active">Activo</span>
            </div>
            <p>Sistema de gestión interna para empresa de venta de camas. Automatización de pedidos, albaranes y sincronización con Holded ERP.</p>
            <div class="tags">
              <span>Google AppScript</span>
              <span>Clasp</span>
              <span>Holded API</span>
              <span>Google Sheets</span>
            </div>
          </div>
        </div>
        <div class="project-card">
          <div class="project-img project-img--code">
            <span>🛍️</span>
            <p>Shopify App</p>
          </div>
          <div class="project-body">
            <div class="project-header">
              <h3>Shopify Order Tracker</h3>
              <span class="tag tag-wip">En desarrollo</span>
            </div>
            <p>App para el Shopify App Store que permite a clientes consultar el estado de sus pedidos introduciendo su email y número de orden.</p>
            <div class="tags">
              <span>Remix</span>
              <span>Shopify API</span>
              <span>Prisma</span>
              <span>Node.js</span>
            </div>
          </div>
        </div>
        <div class="project-card">
          <img class="project-img project-img--screenshot" src="/proj-anime-kawaii.png" alt="Anime Kawaii" loading="lazy" />
          <div class="project-body">
            <div class="project-header">
              <h3>Anime Kawaii</h3>
              <span class="tag tag-paused">Finalizado</span>
            </div>
            <p>Portal de noticias y contenido anime con sistema de artículos, galerías, categorías y diseño personalizado.</p>
            <div class="tags">
              <span>WordPress</span>
              <span>PHP</span>
              <span>CSS</span>
              <span>MySQL</span>
            </div>
          </div>
        </div>
        <div class="project-card">
          <img class="project-img project-img--screenshot" src="/proj-game-spain.png" alt="Game Spain" loading="lazy" />
          <div class="project-body">
            <div class="project-header">
              <h3>Game Spain</h3>
              <span class="tag tag-paused">Finalizado</span>
            </div>
            <p>Comunidad gaming con noticias, foro, integración con Discord y secciones por juego. Diseño dark theme personalizado.</p>
            <div class="tags">
              <span>WordPress</span>
              <span>PHP</span>
              <span>Discord API</span>
              <span>CSS</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACTO -->
  <section id="contacto">
    <div class="container container-narrow">
      <h2>Hablemos</h2>
      <p class="section-sub">Cuéntame qué necesitas y te respondo en menos de 24 horas</p>
      <form class="contact-form" action="mailto:pcmaxbarcelona@outlook.es" method="POST" enctype="text/plain">
        <div class="form-row">
          <div class="form-group">
            <label for="nombre">Nombre</label>
            <input type="text" id="nombre" name="Nombre" placeholder="Tu nombre" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="Email" placeholder="tu@email.com" required />
          </div>
        </div>
        <div class="form-group">
          <label for="servicio">¿Qué necesitas?</label>
          <select id="servicio" name="Servicio">
            <option value="">Selecciona un servicio</option>
            <option>Reparación de ordenador</option>
            <option>Desarrollo web</option>
            <option>Programación a medida</option>
            <option>Otro</option>
          </select>
        </div>
        <div class="form-group">
          <label for="mensaje">Mensaje</label>
          <textarea id="mensaje" name="Mensaje" placeholder="Cuéntame qué necesitas..." rows="5" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-full">Enviar mensaje</button>
      </form>
      <p class="contact-alt">O escríbeme directamente a <a href="mailto:pcmaxbarcelona@outlook.es">pcmaxbarcelona@outlook.es</a></p>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="container footer-inner">
      <img src="/logo.png" alt="PC MAX" height="32" />
      <p>© 2026 PC MAX · Barcelona</p>
      <a href="mailto:pcmaxbarcelona@outlook.es" class="footer-email">pcmaxbarcelona@outlook.es</a>
    </div>
  </footer>

</body>
</html>

<style is:global>
  :root {
    --bg: #0d0d0d;
    --surface: #141414;
    --surface2: #1c1c1c;
    --border: #272727;
    --accent: #5ba8d4;
    --accent-hover: #7abde8;
    --text: #f0f0f0;
    --muted: #888;
    --radius: 12px;
    --max: 1100px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  a { color: inherit; text-decoration: none; }

  /* NAV */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(13,13,13,0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav-logo { display: flex; align-items: center; }
  .nav-logo img { display: block; }

  nav ul {
    display: flex;
    list-style: none;
    gap: 28px;
    margin-left: auto;
  }

  nav ul a {
    font-size: 0.875rem;
    color: var(--muted);
    transition: color 0.2s;
  }
  nav ul a:hover { color: var(--text); }

  /* BUTTONS */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 22px;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
    font-family: inherit;
    white-space: nowrap;
  }
  .btn-sm { padding: 7px 16px; font-size: 0.825rem; }
  .btn-primary { background: var(--accent); color: #0a0a0a; font-weight: 600; }
  .btn-primary:hover { background: var(--accent-hover); transform: translateY(-1px); }
  .btn-ghost {
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--border);
  }
  .btn-ghost:hover { color: var(--text); border-color: #555; }
  .btn-full { width: 100%; padding: 14px; font-size: 1rem; }

  /* HERO */
  .hero {
    min-height: calc(100vh - 64px);
    display: flex;
    align-items: center;
    background: radial-gradient(ellipse 80% 60% at 50% -5%, rgba(91,168,212,0.1), transparent 70%);
  }

  .hero-inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 80px 24px;
    text-align: center;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 14px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 99px;
    font-size: 0.8rem;
    color: var(--muted);
    margin-bottom: 28px;
  }

  .hero h1 {
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 20px;
    letter-spacing: -0.03em;
  }

  .accent { color: var(--accent); }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--muted);
    margin-bottom: 40px;
    letter-spacing: 0.01em;
  }

  .hero-ctas {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* SECTIONS */
  section { padding: 100px 0; }
  .dark-section { background: var(--surface); }

  .container {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 24px;
  }
  .container-narrow { max-width: 680px; }

  h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }

  .section-sub {
    text-align: center;
    color: var(--muted);
    margin-bottom: 56px;
    font-size: 1rem;
  }

  /* SERVICE CARDS */
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px;
    transition: border-color 0.25s, transform 0.25s;
  }
  .card:hover { border-color: var(--accent); transform: translateY(-3px); }

  .card.featured {
    border-color: rgba(91,168,212,0.4);
    background: linear-gradient(145deg, rgba(91,168,212,0.07) 0%, var(--surface) 60%);
    position: relative;
  }

  .card-icon { font-size: 1.8rem; margin-bottom: 16px; }
  .card h3 { font-size: 1.05rem; font-weight: 600; margin-bottom: 10px; }
  .card p { color: var(--muted); font-size: 0.875rem; margin-bottom: 18px; line-height: 1.7; }

  .card ul { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .card ul li {
    font-size: 0.825rem;
    color: var(--muted);
    padding-left: 18px;
    position: relative;
  }
  .card ul li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.8rem;
  }

  /* PROJECT CARDS */
  .project-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.25s, transform 0.25s;
  }
  .project-card:hover { border-color: var(--accent); transform: translateY(-2px); }

  .project-img {
    width: 100%;
    height: 180px;
    display: block;
    object-fit: cover;
    object-position: top;
  }

  .project-img--screenshot {
    border-bottom: 1px solid var(--border);
  }

  .project-img--code {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
  }
  .project-img--code span { font-size: 2.5rem; }
  .project-img--code p { font-size: 0.8rem; color: var(--muted); }

  .project-body { padding: 20px; }

  .project-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }
  .project-header h3 { font-size: 0.975rem; font-weight: 600; }

  .tag {
    flex-shrink: 0;
    font-size: 0.7rem;
    padding: 3px 9px;
    border-radius: 99px;
    font-weight: 500;
  }
  .tag-active { background: rgba(74,222,128,0.1); color: #4ade80; border: 1px solid rgba(74,222,128,0.2); }
  .tag-wip    { background: rgba(251,191,36,0.1); color: #fbbf24; border: 1px solid rgba(251,191,36,0.2); }
  .tag-paused { background: rgba(156,163,175,0.1); color: #9ca3af; border: 1px solid rgba(156,163,175,0.2); }

  .project-body > p {
    color: var(--muted);
    font-size: 0.85rem;
    margin-bottom: 16px;
    line-height: 1.7;
  }

  .tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .tags span {
    font-size: 0.72rem;
    padding: 3px 8px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--muted);
  }

  /* CONTACT */
  .contact-form {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
    margin-bottom: 20px;
  }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-group { display: flex; flex-direction: column; gap: 7px; margin-bottom: 16px; }
  .form-group:last-of-type { margin-bottom: 24px; }

  label { font-size: 0.825rem; font-weight: 500; color: var(--muted); }

  input, textarea, select {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 14px;
    color: var(--text);
    font-family: inherit;
    font-size: 0.9rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    width: 100%;
  }
  input:focus, textarea:focus, select:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(91,168,212,0.1);
  }
  input::placeholder, textarea::placeholder { color: #444; }
  textarea { resize: vertical; }
  select { cursor: pointer; }
  select option { background: var(--surface2); color: var(--text); }

  .contact-alt {
    text-align: center;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .contact-alt a { color: var(--accent); }
  .contact-alt a:hover { text-decoration: underline; }

  /* FOOTER */
  footer {
    border-top: 1px solid var(--border);
    padding: 32px 0;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }
  footer p { font-size: 0.8rem; color: var(--muted); }
  .footer-email { font-size: 0.8rem; color: var(--muted); transition: color 0.2s; }
  .footer-email:hover { color: var(--accent); }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    nav ul { display: none; }
    .grid-3, .grid-2 { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .hero-ctas { flex-direction: column; align-items: stretch; max-width: 280px; margin: 0 auto; }
    .footer-inner { flex-direction: column; text-align: center; }
    section { padding: 72px 0; }
  }

  @media (max-width: 480px) {
    .hero h1 { font-size: 2.2rem; }
    .nav-inner { padding: 0 16px; }
    .container { padding: 0 16px; }
  }
</style>
